{
  "extends": [
    "development"
  ],
  "hints": {
    "meta-viewport": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": []
      }
    ],
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]"
        ]
      }
    ],
    "no-inline-styles": "off",
    "css-prefix-order": "off",
    "axe/language": [
      "default",
      {
        "html-has-lang": "off"
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_chr <= 142",
    "not and_ff <= 144",
    "not chrome <= 142",
    "not edge <= 142",
    "not firefox <= 145",
    "not ios_saf <= 26",
    "not opera <= 122",
    "not safari <= 26.1",
    "not samsung <= 29"
  ]
}